# Required at runtime ONLY for search_standards (semantic search).
# get_standard and list_standards work fully offline without this.
OPENAI_API_KEY=your_openai_api_key_here

# Required ONLY for rebuilding the bundled standards.db via `python -m chiron_standards.ingest`.
# End users installing from PyPI do not need this.
CSP_API_KEY=your_common_standards_project_api_key_here
